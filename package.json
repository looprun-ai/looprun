{
  "name": "looprun-monorepo",
  "version": "0.6.2",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/looprun-ai/looprun.git"
  },
  "homepage": "https://looprun.ai",
  "bugs": {
    "url": "https://github.com/looprun-ai/looprun/issues"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:proofs": "pnpm -r --if-present test:proofs",
    "test:laws": "pnpm -C packages/core test && node tests/no-bench-drift.test.mjs",
    "proofs:run": "node scripts/proofs/run-proofs.mjs",
    "proofs:record": "node scripts/proofs/make-record.mjs",
    "proofs:matrix": "node scripts/proofs/gen-matrix.mjs",
    "proofs:check": "node scripts/proofs/check-record-required.mjs",
    "proofs:canary": "node scripts/proofs/run-canary.mjs",
    "changeset": "changeset",
    "release": "node scripts/release.mjs --bump=patch",
    "release-minor": "node scripts/release.mjs --bump=minor",
    "release:dry": "node scripts/release.mjs --dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
