{
  "name": "@looprun-ai/mastra",
  "version": "0.5.0",
  "type": "module",
  "description": "looprun on Mastra: LoopRunAgent — a genuine @mastra/core Agent compiled from an AgentSpec, with deterministic guard enforcement (beforeToolCall veto), the terminal protocol, bounded no-tools redrive and honest-abstain exhaustion. Studio-compatible.",
  "keywords": [
    "ai",
    "agents",
    "llm",
    "governance",
    "guardrails",
    "agentspec",
    "mastra",
    "agent"
  ],
  "license": "Apache-2.0",
  "author": "LoopRun Team",
  "homepage": "https://looprun.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/looprun-ai/looprun.git",
    "directory": "packages/mastra"
  },
  "bugs": {
    "url": "https://github.com/looprun-ai/looprun/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:proofs": "vitest run test/proofs --passWithNoTests"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@looprun-ai/core": "workspace:^"
  },
  "peerDependencies": {
    "@mastra/core": "^1.42.0",
    "ai": "^6.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@looprun-ai/models": "workspace:^",
    "@mastra/core": "^1.42.0",
    "@types/node": "^22.0.0",
    "ai": "^6.0.184",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "zod": "^3.24.0"
  }
}
