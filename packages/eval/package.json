{
  "name": "@looprun-ai/eval",
  "version": "0.3.0",
  "type": "module",
  "description": "looprun eval harness: run a generated agent bundle against its generated eval set (invariant gate + Claude-judge protocol + certification), inside any user project. The measured loop of the agentspec skill: screen N=1 → judge → fix → certify N=3 at the bar.",
  "keywords": [
    "ai",
    "agents",
    "llm",
    "governance",
    "guardrails",
    "agentspec",
    "evals",
    "certification",
    "judge"
  ],
  "license": "Apache-2.0",
  "author": "LoopRun Team",
  "homepage": "https://looprun.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/looprun-ai/looprun.git",
    "directory": "packages/eval"
  },
  "bugs": {
    "url": "https://github.com/looprun-ai/looprun/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "looprun-eval": "bin/looprun-eval.mjs"
  },
  "files": [
    "dist",
    "bin",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@looprun-ai/core": "workspace:^",
    "@looprun-ai/mastra": "workspace:^",
    "@looprun-ai/models": "workspace:^",
    "jiti": "^2.4.0"
  },
  "peerDependencies": {
    "@mastra/core": "^1.42.0",
    "ai": "^6.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@mastra/core": "^1.42.0",
    "@types/node": "^22.0.0",
    "ai": "^6.0.184",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "zod": "^3.24.0"
  }
}
