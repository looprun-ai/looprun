{
  "name": "@looprun/eval",
  "version": "0.1.0",
  "type": "module",
  "description": "looprun eval harness: run a generated agent bundle against its generated eval set (invariant gate + Claude-judge protocol + certification), inside any user project. The measured loop of the agentspec skill: screen N=1 → judge → fix → certify N=3 at the bar.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "looprun-eval": "bin/looprun-eval.mjs"
  },
  "files": [
    "dist",
    "bin",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@looprun/core": "workspace:^",
    "@looprun/mastra": "workspace:^",
    "@looprun/models": "workspace:^",
    "jiti": "^2.4.0"
  },
  "peerDependencies": {
    "@mastra/core": "^1.42.0",
    "ai": "^6.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@mastra/core": "^1.42.0",
    "@types/node": "^22.0.0",
    "ai": "^6.0.184",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "zod": "^3.24.0"
  }
}
