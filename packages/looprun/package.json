{
  "name": "looprun",
  "version": "0.1.0",
  "type": "module",
  "description": "looprun — a governance layer for LLM agents on top of agent frameworks (Mastra first). AgentSpec (the map) + deterministic typed guards (the safety kit) + redrive/honest-abstain (the GPS) + a generator skill. `import { LoopRunAgent } from 'looprun/mastra'`.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./mastra": {
      "types": "./dist/mastra.d.ts",
      "default": "./dist/mastra.js"
    },
    "./models": {
      "types": "./dist/models.d.ts",
      "default": "./dist/models.js"
    },
    "./vercel": {
      "types": "./dist/vercel.d.ts",
      "default": "./dist/vercel.js"
    }
  },
  "bin": {
    "looprun": "bin/looprun.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@looprun/core": "workspace:^",
    "@looprun/mastra": "workspace:^",
    "@looprun/models": "workspace:^",
    "@looprun/vercel": "workspace:^"
  },
  "peerDependencies": {
    "@mastra/core": "^1.42.0",
    "ai": "^6.0.0",
    "zod": "^3.24.0"
  },
  "peerDependenciesMeta": {
    "@mastra/core": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mastra/core": "^1.42.0",
    "@types/node": "^22.0.0",
    "ai": "^6.0.184",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  }
}
